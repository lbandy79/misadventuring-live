rules_version = '2';

// Firestore security rules — Phase 1 stopgap.
//
// NOTE: These rules are intentionally permissive because the current app
// has no Firebase Auth (admin uses a client-side password). Phase 8 will
// replace this with role-based rules backed by Firebase Auth custom claims:
//   request.auth.token.role in ['admin', 'gm', 'player', 'audience']
//
// The goals of THIS file are limited:
//   1. Validate reservation/NPC document shape on create.
//   2. Prevent clients from arbitrarily mutating reservation flags
//      after npcCreated flips to true.
//   3. Lock the test/connection-test doc so it can't be abused.
//   4. Leave live-show interaction collections (votes, monster-builder,
//      ship-combat, etc.) open for read/write — admin panel and audience
//      both need write access until Phase 8 introduces auth.

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Reservations ───────────────────────────────────────────────
    match /reservations/{reservationId} {
      allow read: if true;

      allow create: if
        request.resource.data.keys().hasAll(['name','email','accessCode','showId','createdAt','npcCreated'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 80
        && request.resource.data.email is string
        && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
        && request.resource.data.accessCode is string
        && request.resource.data.accessCode.size() == 6
        && request.resource.data.showId is string
        && request.resource.data.npcCreated == false;

      // Updates: only allow flipping npcCreated false→true. Identity fields immutable.
      allow update: if
        resource.data.npcCreated == false
        && request.resource.data.npcCreated == true
        && request.resource.data.name == resource.data.name
        && request.resource.data.email == resource.data.email
        && request.resource.data.accessCode == resource.data.accessCode
        && request.resource.data.showId == resource.data.showId;

      allow delete: if false;
    }

    // ─── NPCs (player-created characters) ───────────────────────────
    match /npcs/{npcId} {
      allow read: if true;

      allow create: if
        request.resource.data.keys().hasAll(['reservationId','showId','systemId','name','createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 60
        && request.resource.data.reservationId is string
        && request.resource.data.showId is string
        && request.resource.data.gmFlagged == false;

      // GM-only fields (gmNotes, gmFlagged) — Phase 8 will gate by role claim.
      // For now, allow updates of those fields without identity changes.
      allow update: if
        request.resource.data.reservationId == resource.data.reservationId
        && request.resource.data.showId == resource.data.showId
        && request.resource.data.name == resource.data.name;

      allow delete: if false; // Phase 8: allow if request.auth.token.role == 'admin'
    }

    // ─── Connection test doc (used by firebase.ts on boot) ──────────
    match /test/{docId} {
      allow read, write: if docId == 'connection-test';
    }

    // ─── Live show interaction state (open until Phase 8 auth) ──────
    // Collections: config, votes, group-roll, monster-builder,
    // decoder-ring, ship-combat, villagers, players.
    match /config/{docId} { allow read, write: if true; }
    match /votes/{docId} { allow read, write: if true; }
    match /group-roll/{docId} { allow read, write: if true; }
    match /monster-builder/{docId} { allow read, write: if true; }
    match /decoder-ring/{docId} { allow read, write: if true; }
    match /ship-combat/{docId} { allow read, write: if true; }
    match /villagers/{docId} { allow read, write: if true; }
    match /players/{docId} { allow read, write: if true; }

    // Default deny — anything not matched above is locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
