# Resend API key — server-side only, never expose to the browser.
# 1. Sign up at https://resend.com
# 2. Create an API key under "API Keys" in the dashboard (send-only scope is enough)
# 3. Verify your sending domain (themisadventuringparty.com) under "Domains"
#    — follow Resend's DNS verification steps (SPF, DKIM, DMARC records)
# 4. Copy this file to functions/.env and paste your key below.
#    Firebase Functions picks up functions/.env automatically during local emulation
#    and via `firebase functions:secrets:set` for production.
#
# Production deployment:
#   firebase functions:secrets:set RESEND_API_KEY
#   (paste key when prompted — stored in Google Secret Manager)
RESEND_API_KEY=

# Sending address — must match your verified Resend domain.
# Example: shows@themisadventuringparty.com
RESEND_FROM_ADDRESS=

# Public base URL — used to build magic links in emails.
APP_BASE_URL=https://themisadventuringparty.com
