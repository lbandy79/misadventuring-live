# Firebase web config (from Firebase Console > Project Settings > Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Admin gate moved to Firebase Auth + config/admins.emails allowlist (Phase 9A).
# No password env var is required. Add admin emails to the `emails` array of
# the `config/admins` Firestore doc.

# Public URL used in email links and QR codes (defaults to prod in functions/.env).
VITE_APP_BASE_URL=

# Email via Resend — server-side only. API key lives in functions/.env, not here.
# See functions/.env.example for the full Resend setup guide.
# The Vite app never touches the Resend key — it calls a Firebase callable function.

# EmailJS (legacy reservation confirmations — Phase 1, kept for Betawave recap).
# Not used in the May 2026 save flow.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
