{
  "system": {
    "id": "honey-heist",
    "name": "Honey Heist",
    "edition": "2017",
    "publisher": "Grant Howitt",
    "description": "You have a complex plan that requires precise timing. You are also a goddamn bear.",
    "credits": "A game by Grant Howitt (2017). With thanks to All Out of Bubblegum, 3:16, and (weirdly) Polaris."
  },

  "stats": [
    {
      "id": "bear",
      "name": "Bear",
      "starting": 3,
      "max": 6,
      "description": "Use to maul stuff, run and climb, shrug off damage, scare people, and generally do bear stuff."
    },
    {
      "id": "criminal",
      "name": "Criminal",
      "starting": 3,
      "max": 6,
      "description": "Use to do anything not directly related to being a bear."
    }
  ],

  "dice": {
    "available": ["d6"],
    "mechanic": {
      "default": "When you act and the outcome is in doubt, roll a d6. Equal to or under the relevant stat = success. Over = failure.",
      "advantage": "If you are using your bear special skill or doing something related to your role, roll 2d6 and pick the lowest."
    }
  },

  "states": {
    "frustration": {
      "trigger": "The plan fails and you run into difficulty.",
      "effect": "Move one point from Criminal into Bear."
    },
    "creed": {
      "trigger": "The plan goes off without a hitch.",
      "effect": "Move one point from Bear into Criminal."
    },
    "voluntaryShifts": [
      {
        "direction": "bear-to-criminal",
        "method": "Flashback scene where the bears plan the heist over coffee and cigarettes in the back room of a seedy bar."
      },
      {
        "direction": "criminal-to-bear",
        "method": "Eat a load of honey."
      }
    ],
    "endStates": {
      "criminalMaxed": {
        "stat": "criminal",
        "atValue": 6,
        "result": "Lured into a life of crime. You betray the party."
      },
      "bearMaxed": {
        "stat": "bear",
        "atValue": 6,
        "result": "You flip out bear-style and lose it. Animal control picks you up in about half an hour."
      }
    }
  },

  "characterCreation": {
    "_comment": "Roll 3D6 to determine descriptor, role, and bear type. Audience does not build characters in the Mad Libs format; cast plays pre-built bears.",
    "tables": {
      "descriptor": [
        "Rookie", "Washed-Up", "Retired", "Unhinged", "Slick", "Incompetent"
      ],
      "role": [
        "Muscle", "Brains", "Driver", "Hacker", "Thief", "Face"
      ],
      "bearType": [
        { "id": "grizzly", "name": "Grizzly", "skill": "Terrify" },
        { "id": "polar", "name": "Polar", "skill": "Swim" },
        { "id": "panda", "name": "Panda", "skill": "Eat anything that looks like bamboo" },
        { "id": "black", "name": "Black", "skill": "Climb" },
        { "id": "sun", "name": "Sun", "skill": "Sense Honey" },
        { "id": "honey-badger", "name": "Honey Badger", "skill": "Carnage" }
      ],
      "bonusHat": {
        "_comment": "Roll 1d8 if your bear wants a hat.",
        "options": [
          "Trilby", "Top", "Bowler", "Flat-Cap", "Cowboy", "Fez", "Crown", "Roll Twice"
        ]
      }
    }
  },

  "gmTables": {
    "_comment": "Original Howitt setup tables, kept full as a GM fallback. The Mad Libs in showConfig override these with TMP-themed paths.",
    "conventionOrganizer": [
      "Cunning and sly",
      "Greedy and wicked",
      "Clueless and exploitable",
      "Maybe too obsessed with honey",
      "A spoilt trust-fund kid",
      "Ruthless and corrupt"
    ],
    "honeyConLocation": {
      "adjective": ["Creepy", "Busy", "Run-Down", "Beautiful", "Dangerous", "Lavish"],
      "place": ["Lakeside Camp", "Fishing Village", "Metropolitan City", "Convention Centre", "Truck Convoy", "Wilderness Retreat"]
    },
    "thePrize": [
      "Ultradense megahoney from especially posh bees",
      "A briefcase of pure manuka extract worth $5m",
      "The Queen of All Bees, once exiled, now returned",
      "Black Orchid Honey, which turns anyone who eats it into a goth",
      "Abraham Lincoln's beehive, thought to be haunted by his ghost",
      "Miss Universe 2017, an especially attractive Bee"
    ],
    "twist": [
      "This place is rigged to blow",
      "The cops are en route",
      "There's a rival team of bears",
      "They've been set up",
      "The prize is a fake",
      "The bees are angry"
    ],
    "securityFeatures": {
      "_comment": "Roll twice on this table.",
      "options": [
        "Armed Guards",
        "Electronically locked doors",
        "Laser tripwire grids",
        "CCTV network",
        "\"Impenetrable\" Vault",
        "Poison Gas"
      ]
    }
  },

  "showConfig": {
    "_comment": "Mad Libs Honey Heist at Lucky Straws, May 23 2026. The Mad Libs IS the login. Audience members build an NPC through the creation form, which is the only entry point. Personal fields shape their NPC identity. World fields aggregate as shared votes that the GM resolves at showtime. Stingers (Beats) are pushed live by the GM to individual NPCs.",
    "showId": "honey-heist-madlibs-2026-05-23",
    "showName": "Mad Libs Honey Heist",
    "seriesName": "TMP One-Shots",
    "venue": "Lucky Straws",
    "date": "2026-05-23",
    "format": "npc-mad-libs",

    "theme": {
      "beatLabel": "Stinger",
      "campaignId": "honey-heist",
      "primaryColor": "#1c1c1c",
      "accentColor": "#e0a022"
    },

    "npcCreation": {
      "_comment": "Blind word collection — labels show word type only, no sentence context. Comedy is in the reveal. displayNameTemplate uses {fieldId} from personal fields only.",
      "displayNameTemplate": "{adjective} {job_title}, {tagline}",
      "revealTemplate": "A {adjective} {job_title}, reportedly {tagline}, attending {setting} as a {noun}.",
      "fields": [
        {
          "id": "adjective",
          "type": "ADJECTIVE",
          "fieldType": "personal",
          "label": "Give me an adjective.",
          "options": ["suspicious", "licensed", "enormous", "chill"]
        },
        {
          "id": "job_title",
          "type": "JOB TITLE",
          "fieldType": "personal",
          "label": "Give me a job title.",
          "options": ["manager", "inspector", "consultant", "intern"]
        },
        {
          "id": "tagline",
          "type": "ADJECTIVE",
          "fieldType": "personal",
          "label": "One more adjective.",
          "options": ["notorious", "retired", "haunted", "unlicensed"]
        },
        {
          "id": "noun",
          "type": "NOUN",
          "fieldType": "personal",
          "label": "Give me a noun.",
          "options": ["tourist", "stranger", "journalist", "plus-one"]
        },
        {
          "id": "setting",
          "type": "PLACE",
          "fieldType": "world",
          "label": "Give me a place.",
          "_comment": "World-voted. Options align with original themes: Theme Park / Outer Space / Time Travel / Monster Movie.",
          "options": [
            "a theme park",
            "a space station",
            "a time loop",
            "a film set"
          ]
        },
        {
          "id": "prize",
          "type": "NOUN",
          "fieldType": "world",
          "label": "Give me a noun.",
          "options": [
            "the mascot",
            "old honey",
            "a film reel",
            "something alive"
          ]
        }
      ]
    },

    "stingerQueue": {
      "_comment": "Blind word collection — slot labels are hidden from the audience during collection. Reveal happens on GM approval. Same ID-keyed substitution as npcCreation. Each promptPreset has its own responseSlots tuned for that scenario.",
      "defaultDuration": 30,
      "responseTemplate": "I {verb} the {noun} and now the {place} is {adjective}.",
      "responseSlots": [
        {
          "id": "verb",
          "type": "VERB (past tense)",
          "label": "What you did",
          "options": ["ate", "leaked", "panicked", "monetized"]
        },
        {
          "id": "noun",
          "type": "NOUN",
          "label": "What you affected",
          "options": ["jar", "disguise", "alibi", "paperwork"]
        },
        {
          "id": "place",
          "type": "PLACE",
          "label": "Where this happened",
          "options": ["bathroom", "gift shop", "parking lot", "supply closet"]
        },
        {
          "id": "adjective",
          "type": "ADJECTIVE",
          "label": "How it is now",
          "options": ["on fire", "worse", "trending", "classified"]
        }
      ],
      "promptPresets": [
        {
          "id": "worst-moment",
          "label": "Walk in at the worst moment",
          "prompt": "You just walked into the worst possible moment. What do you do?",
          "responseSlots": [
            {
              "id": "verb",
              "type": "VERB (past tense)",
              "label": "What you did",
              "options": ["photographed", "livestreamed", "narrated", "auctioned"]
            },
            {
              "id": "noun",
              "type": "NOUN",
              "label": "What you affected",
              "options": ["mascot head", "escape route", "security override", "emergency honey"]
            },
            {
              "id": "place",
              "type": "PLACE",
              "label": "Where this is now",
              "options": ["main stage", "exhibit hall B", "feeds", "vault anteroom"]
            },
            {
              "id": "adjective",
              "type": "ADJECTIVE",
              "label": "How it is now",
              "options": ["trending", "a crime scene", "very witnessed", "legally complicated"]
            }
          ]
        },
        {
          "id": "witness",
          "label": "See something you shouldn't have",
          "prompt": "You saw something you absolutely should not have seen. Now what?",
          "responseSlots": [
            {
              "id": "verb",
              "type": "VERB (past tense)",
              "label": "What you did with it",
              "options": ["described", "reported", "identified", "sketched"]
            },
            {
              "id": "noun",
              "type": "NOUN",
              "label": "What you saw",
              "options": ["bear disguise", "honey drop", "whole plan", "backup signal"]
            },
            {
              "id": "place",
              "type": "PLACE",
              "label": "Where it ended up",
              "options": ["front page", "official record", "security office", "group chat"]
            },
            {
              "id": "adjective",
              "type": "ADJECTIVE",
              "label": "How it is now",
              "options": ["documented", "no longer deniable", "on the news", "a statement"]
            }
          ]
        },
        {
          "id": "accident",
          "label": "Make it worse",
          "prompt": "You tried to stay out of it. That's over. How did you accidentally make it worse?",
          "responseSlots": [
            {
              "id": "verb",
              "type": "VERB (past tense)",
              "label": "What you did",
              "options": ["announced", "helped", "narrated", "fixed"]
            },
            {
              "id": "noun",
              "type": "NOUN",
              "label": "What you touched",
              "options": ["backup plan", "wrong bear", "whole thing", "getaway car"]
            },
            {
              "id": "place",
              "type": "PLACE",
              "label": "What paid for it",
              "options": ["exits", "main stage", "parking structure", "timeline"]
            },
            {
              "id": "adjective",
              "type": "ADJECTIVE",
              "label": "How it is now",
              "options": ["worse somehow", "a podcast", "on fire", "permanent"]
            }
          ]
        },
        {
          "id": "distraction",
          "label": "Be the distraction",
          "prompt": "The bears need three seconds and a distraction. You're the only one here. Go.",
          "responseSlots": [
            {
              "id": "verb",
              "type": "VERB (past tense)",
              "label": "What you did",
              "options": ["performed", "announced", "narrated", "sang"]
            },
            {
              "id": "noun",
              "type": "NOUN",
              "label": "What it was",
              "options": ["interpretive fall", "beekeeper credentials", "emergency dance", "exit speech"]
            },
            {
              "id": "place",
              "type": "PLACE",
              "label": "Where it landed",
              "options": ["stage", "exhibit hall B", "front desk", "parking lot"]
            },
            {
              "id": "adjective",
              "type": "ADJECTIVE",
              "label": "How it is now",
              "options": ["still happening", "too successful", "a thing now", "technically a performance"]
            }
          ]
        }
      ]
    }
  }
}
