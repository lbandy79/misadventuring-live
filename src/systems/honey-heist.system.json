          "responseTemplate": "I {verb} the {noun} near the {place} — clearly {adjective}.",
          "responseSlots": [
            {
              "id": "verb",
              "type": "VERB (past tense)",
              "label": "What you did",
              "options": ["greeted", "complimented", "issued a badge to", "held the door for"],
