  "showConfig": {
    "_comment": "Mad Libs Honey Heist at Lucky Straws, May 23 2026. The Mad Libs IS the login. Audience members build an NPC through the creation form, which is the only entry point. Personal fields shape their NPC identity. World fields aggregate as shared votes that the GM resolves at showtime. Stingers (Beats) are pushed live by the GM to individual NPCs.",
    "showId": "honey-heist-madlibs-2026-05-23",
    "showName": "Mad Libs Honey Heist",
    "seriesName": "TMP One-Shots",
    "venue": "Lucky Straws",
    "date": "2026-05-23",
    "format": "npc-mad-libs",

    "theme": {
      "beatLabel": "Stinger",
      "campaignId": "honey-heist",
      "primaryColor": "#1c1c1c",
      "accentColor": "#e0a022"
    },

    "npcCreation": {
      "_comment": "Blind word collection — labels show word type only, no sentence context. Comedy is in the reveal. displayNameTemplate uses {fieldId} from personal fields only.",
      "displayNameTemplate": "{adjective} {job_title}, {tagline}",
      "revealTemplate": "A {adjective} {job_title}, reportedly {tagline}, at a {setting}.",
      "fields": [
        {
          "id": "adjective",
          "type": "ADJECTIVE",
          "fieldType": "personal",
          "label": "Give me an adjective.",
          "options": ["suspicious", "licensed", "enormous", "chill"]
        },
        {
          "id": "job_title",
          "type": "JOB TITLE",
          "fieldType": "personal",
          "label": "Give me a job title.",
          "options": ["manager", "inspector", "consultant", "intern"]
        },
        {
          "id": "tagline",
          "type": "ADJECTIVE",
          "fieldType": "personal",
          "label": "One more adjective.",
          "options": ["notorious", "retired", "haunted", "unlicensed"]
        },
        {
          "id": "setting",
          "type": "PLACE",
          "fieldType": "world",
          "label": "Give me a place.",
          "_comment": "World-voted. Options align with original themes: Theme Park / Outer Space / Time Travel / Monster Movie.",
          "options": [
            "theme park",
            "space station",
            "comic convention",
            "film set"
          ]
        },
        {
          "id": "prize",
          "type": "NOUN",
          "fieldType": "world",
          "label": "Give me a noun.",
          "options": [
            "the mascot",
            "old honey",
            "a film reel",
            "something alive"
          ]
        }
      ]
    },

    "stingerQueue": {
      "_comment": "Blind word collection — slot labels are hidden from the audience during collection. Reveal happens on GM approval. freeText slots render a text input instead of radio buttons.",
      "defaultDuration": 30,
      "responseTemplate": "I {verb} the {noun} and now the {place} is {adjective}.",
      "responseSlots": [
        {
          "id": "verb",
          "type": "VERB (past tense)",
          "label": "What you did",
          "options": ["handled", "secured", "ignored", "reported"],
          "freeText": true
        },
        {
          "id": "noun",
          "type": "NOUN",
          "label": "What you affected",
          "options": ["situation", "honey inventory", "bear-related incident", "whole thing"],
          "freeText": true
        },
        {
          "id": "place",
          "type": "PLACE",
          "label": "Where this happened",
          "options": ["exhibit", "gift shop", "parking lot", "record"],
          "freeText": true
        },
        {
          "id": "adjective",
          "type": "ADJECTIVE",
          "label": "How it is now",
          "options": ["fine", "not my problem", "under review", "technically resolved"],
          "freeText": true
        }
      ],
      "promptPresets": [
        {
          "id": "saw-the-bears",
          "label": "You saw the bears",
          "prompt": "You definitely just saw bears in disguise near the honey exhibit. What's your official account?",
          "responseTemplate": "I {verb} the {noun} at the {place} and I can confirm it was {adjective}.",
          "responseSlots": [
            {
              "id": "verb",
              "type": "VERB (past tense)",
              "label": "What you did",
              "options": ["observed", "documented", "absolutely did not see", "reported seeing"],
              "freeText": true
            },
            {
              "id": "noun",
              "type": "NOUN",
              "label": "What you saw",
              "options": ["three bears", "suspicious honey activity", "a trenchcoat situation", "what appeared to be a unit"],
              "freeText": true
            },
            {
              "id": "place",
              "type": "PLACE",
              "label": "Where this happened",
              "options": ["honey exhibit", "back exit", "gift shop", "main stage"],
              "freeText": true
            },
            {
              "id": "adjective",
              "type": "ADJECTIVE",
              "label": "How it is now",
              "options": ["unrelated to me", "not my department", "a weather event", "contained"],
              "freeText": true
            }
          ]
        },
        {
          "id": "you-helped",
          "label": "You helped (sort of)",
