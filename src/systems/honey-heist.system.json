          "responseTemplate": "I {verb} the {noun} from the {place} and now it's {adjective}.",
          "responseSlots": [
            {
              "id": "verb",
              "type": "VERB (past tense)",
              "label": "What you did",
              "options": ["moved", "hid", "definitely did not steal", "relocated for safety"],
              "freeText": true
            },
            {
              "id": "noun",
              "type": "NOUN",
              "label": "What you touched",
              "options": ["honey reserve", "exhibit sign", "security badge", "bear costume piece"],
