        },
        {
          "id": "distraction",
          "label": "You were the distraction",
          "prompt": "The bears needed three seconds and a distraction. You were there. It counts.",
          "responseTemplate": "I {verb} a {noun} in the {place} and it was {adjective}.",
          "responseSlots": [
            {
              "id": "verb",
              "type": "VERB (past tense)",
